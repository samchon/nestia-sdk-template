{
  "name": "@ORGANIZATION/PROJECT-api",
  "version": "0.1.0",
  "description": "SDK library generated by Nestia",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./lib/*": "./src/*.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "main": "lib/index.mjs",
    "module": "lib/index.mjs",
    "types": "lib/index.d.ts",
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "import": "./lib/index.mjs",
        "default": "./lib/index.js"
      },
      "./lib/*": {
        "types": "./lib/*.d.ts",
        "import": "./lib/*.mjs",
        "default": "./lib/*.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "rimraf lib && ttsc && rolldown -c",
    "build:test": "rimraf bin && ttsc --project test/tsconfig.json",
    "deploy": "pnpm run build && pnpm publish",
    "dev": "pnpm run build:test --watch",
    "hello": "node hello",
    "start": "ttsx test/start.ts",
    "swagger": "ttsx test/swagger.ts",
    "test": "ttsx test/index.ts",
    "test:simulate": "ttsx test/index.ts --simulate true"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia/issues"
  },
  "homepage": "https://nestia.io",
  "files": [
    "lib",
    "swagger.json",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "@nestia/fetcher": "^12.0.0",
    "tgrid": "^1.2.1",
    "typia": "^13.1.1"
  },
  "devDependencies": {
    "@nestia/e2e": "^12.0.0",
    "@ttsc/unplugin": "^0.19.2",
    "@types/express": "^4.17.21",
    "@types/inquirer": "8.2.5",
    "@types/swagger-ui-express": "^4.1.6",
    "chalk": "4.1.2",
    "commander": "^10.0.0",
    "express": "^4.19.2",
    "inquirer": "8.2.5",
    "rimraf": "^5.0.5",
    "rolldown": "^1.1.5",
    "swagger-ui-express": "^5.0.0",
    "tinyglobby": "^0.2.17",
    "ttsc": "^0.19.2",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@10.19.0"
}
